---
import Base from '../../layouts/Base.astro';
import { getBlogSorted, getRelatedPosts, type BlogPost } from '../../data/blog';

export async function getStaticPaths() {
  return getBlogSorted().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props { post: BlogPost }
const { post } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const related = getRelatedPosts(post.slug, 3);
const canonical = new URL(`/blog/${post.slug}`, Astro.site ?? 'https://gonglue.xyz').toString();
---

<Base title={post.title} description={post.excerpt}>
  <!-- SEO: BlogPosting JSON-LD -->
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: post.title,
      description: post.excerpt,
      datePublished: post.date,
      dateModified: post.date,
      author: {
        '@type': 'Person',
        name: 'Mavis',
        jobTitle: 'Editorial lead',
        worksFor: { '@type': 'Organization', name: 'AI Agents Hub', url: 'https://gonglue.xyz' },
        url: 'https://gonglue.xyz/about#editorial-team',
        description: 'Six years writing about developer tools and AI infrastructure. Personal reviewer of every agent in the 62-agent directory.',
      },
      publisher: { '@type': 'Organization', name: 'AI Agents Hub', url: 'https://gonglue.xyz' },
      mainEntityOfPage: canonical,
      url: canonical,
      keywords: post.tags.join(', '),
    })}
  />

  <article class="post">
    <div class="container">
      <header class="post-header">
        <a href={`${base}/blog`} class="back-link">← Back to Blog</a>
        <h1>{post.title}</h1>
        <p class="post-excerpt">{post.excerpt}</p>
        <div class="post-meta">
          <span>{post.author}</span>
          <span class="dot">·</span>
          <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <span class="dot">·</span>
          <span>{post.readingTime} min read</span>
        </div>
      </header>

      <div class="post-content" set:html={post.content} />

      <footer class="post-footer">
        <div class="post-tags">
          {post.tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>

        <!-- Author bio (E-E-A-T signal: per-article attribution to a real person) -->
        <aside class="author-bio" aria-label="About the author">
          <div class="author-avatar" aria-hidden="true">M</div>
          <div class="author-body">
            <div class="author-name">Mavis</div>
            <div class="author-role">Editorial lead, AI Agents Hub</div>
            <p class="author-text">
              Mavis has spent the last six years writing about developer tools and
              AI infrastructure. She personally tests every agent in our
              <a href="/">62-agent directory</a> and writes the long-form analysis
              posts on this blog. This post is part of our
              <a href="/blog">editorial series</a> — every entry is written, edited,
              and fact-checked by a person, not auto-generated.
            </p>
            <p class="author-cta">
              Spotted an error? <a href="/contact">Email us</a> · Read about our
              <a href="/about#editorial-team">editorial process</a>.
            </p>
          </div>
        </aside>
      </footer>
    </div>
  </article>

  {related.length > 0 && (
    <section class="related">
      <div class="container">
        <h2>More from the blog</h2>
        <div class="related-grid">
          {related.map((p) => (
            <a href={`${base}/blog/${p.slug}`} class="related-card">
              <div class="related-meta">
                <time datetime={p.date}>{new Date(p.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</time>
                <span class="dot">·</span>
                <span>{p.readingTime} min</span>
              </div>
              <h3>{p.title}</h3>
              <p>{p.excerpt}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Base>

<style is:global>
  .post {
    padding: 60px 0 40px;
  }
  .post-header {
    max-width: 760px;
    margin: 0 auto 40px;
  }
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 24px;
  }
  .back-link:hover {
    color: var(--text);
  }
  .post-header h1 {
    font-size: 44px;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  .post-excerpt {
    color: var(--text-muted);
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 20px;
  }
  .post-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 14px;
    color: var(--text-muted);
  }
  .post-meta .dot {
    color: var(--border);
  }
  .post-content {
    max-width: 760px;
    margin: 0 auto;
    font-size: 17px;
    line-height: 1.75;
    color: var(--text);
  }
  .post-content h2 {
    font-size: 28px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 48px 0 16px;
  }
  .post-content h2:first-child {
    margin-top: 0;
  }
  .post-content p {
    margin: 0 0 20px;
  }
  .post-content strong {
    font-weight: 600;
  }
  .post-content a {
    color: #818cf8;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .post-content code {
    background: var(--surface-2);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: 'SF Mono', Menlo, Consolas, monospace;
  }
  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 15px;
  }
  .post-content figure {
    margin: 32px -16px;
  }
  .post-content figure img {
    width: 100%;
    height: auto;
    border-radius: 14px;
    display: block;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.18);
  }
  .post-content figcaption {
    font-size: 14px;
    color: var(--text-muted);
    text-align: center;
    margin-top: 12px;
    font-style: italic;
    line-height: 1.5;
    padding: 0 16px;
  }
  .post-content th,
  .post-content td {
    text-align: left;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .post-content th {
    font-weight: 600;
    color: var(--text);
    background: var(--surface-2);
  }
  .post-content tbody tr:last-child td {
    border-bottom: none;
  }
  .post-footer {
    max-width: 760px;
    margin: 48px auto 0;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .post-tags .tag {
    display: inline-block;
    padding: 4px 12px;
    font-size: 12px;
    color: var(--text-muted);
    background: var(--surface-2);
    border-radius: 999px;
  }
  .author-bio {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    margin-top: 32px;
    padding: 20px 24px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 12px;
  }
  .author-avatar {
    flex: 0 0 48px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #6366f1, #818cf8);
    color: #fff;
    font-size: 20px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .author-body {
    flex: 1;
    min-width: 0;
  }
  .author-name {
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }
  .author-role {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .author-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 8px;
  }
  .author-text a {
    color: #818cf8;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .author-cta {
    font-size: 13px;
    color: var(--text-muted);
    margin: 0;
  }
  .author-cta a {
    color: #818cf8;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .related {
    padding: 40px 0 80px;
    background: var(--surface-2);
  }
  .related h2 {
    font-size: 24px;
    margin: 0 0 20px;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .related-card {
    display: block;
    padding: 20px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease;
  }
  .related-card:hover {
    border-color: var(--accent, #6366f1);
  }
  .related-card h3 {
    font-size: 16px;
    line-height: 1.35;
    margin: 8px 0 8px;
  }
  .related-card p {
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .related-meta {
    display: flex;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
  }
  .related-meta .dot {
    color: var(--border);
  }
</style>
