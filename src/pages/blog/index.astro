---
import Base from '../../layouts/Base.astro';
import { getBlogSorted, type BlogPost } from '../../data/blog';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const posts = getBlogSorted();
---

<Base
  title="Blog"
  description="Long-form analysis of AI agents: comparison guides, decision frameworks, and how-to walkthroughs. Drawn from our 62-agent directory."
>
  <section class="blog-hero">
    <div class="container">
      <h1>The <span class="grad">Blog</span></h1>
      <p>
        Long-form analysis of AI agents — comparison guides, decision frameworks, and how-to walkthroughs.
        Every post is drawn from the 62 detailed profiles in our <a href={base + '/'}>directory</a>.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Latest</h2>
        <span class="count">{posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
      </div>

      <div class="blog-grid">
        {posts.map((post: BlogPost) => (
          <a href={`${base}/blog/${post.slug}`} class="blog-card">
            {post.coverThumb && (
              <div class="blog-card-cover">
                <img src={post.coverThumb} alt="" loading="lazy" decoding="async" width="600" height="335" />
              </div>
            )}
            <div class="blog-card-body">
              <div class="blog-card-meta">
                <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                <span class="dot">·</span>
                <span>{post.readingTime} min read</span>
              </div>
              <h3 class="blog-card-title">{post.title}</h3>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <div class="blog-card-tags">
                {post.tags.slice(0, 4).map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .blog-hero {
    padding: 80px 0 40px;
    text-align: center;
  }
  .blog-hero h1 {
    font-size: 56px;
    line-height: 1.1;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }
  .blog-hero p {
    color: var(--text-muted);
    font-size: 18px;
    max-width: 640px;
    margin: 0 auto;
  }
  .grad {
    background: linear-gradient(135deg, #6366f1, #ec4899);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    margin-top: 32px;
  }
  @media (max-width: 720px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
  }
  .blog-card:hover {
    border-color: var(--accent, #6366f1);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(99, 102, 241, 0.15);
  }
  .blog-card-cover {
    aspect-ratio: 16/9;
    background: var(--surface-2);
    overflow: hidden;
  }
  .blog-card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .blog-card:hover .blog-card-cover img {
    transform: scale(1.03);
  }
  .blog-card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px 24px 24px;
    flex: 1;
  }
  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
  }
  .blog-card-meta .dot {
    color: var(--border);
  }
  .blog-card-title {
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0;
    color: var(--text);
  }
  .blog-card-excerpt {
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 4px;
  }
  .tag {
    display: inline-block;
    padding: 3px 10px;
    font-size: 11px;
    color: var(--text-muted);
    background: var(--surface-2);
    border-radius: 999px;
  }
  .blog-row-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 12px;
  }
  .blog-row-meta .dot {
    color: var(--border);
  }
  .blog-row-title {
    font-size: 24px;
    line-height: 1.3;
    margin: 0 0 10px;
    letter-spacing: -0.01em;
  }
  .blog-row-excerpt {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.6;
    margin: 0 0 16px;
  }
  .blog-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .tag {
    display: inline-block;
    padding: 3px 10px;
    font-size: 12px;
    color: var(--text-muted);
    background: var(--surface-2);
    border-radius: 999px;
  }
</style>
