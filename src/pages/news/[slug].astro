---
import Base from '../../layouts/Base.astro';
import { news, categoryAccent, type NewsCategory } from '../../data/news';

// 静态构建：为每条新闻生成独立页面
export function getStaticPaths() {
  return news.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categoryIcon: Record<NewsCategory, string> = {
  release: '🚀',
  funding: '💰',
  research: '🔬',
  industry: '📈',
  regulation: '⚖️',
};

// 相关新闻：同分类的其他 3 条
const related = news
  .filter((n) => n.category === item.category && n.slug !== item.slug)
  .slice(0, 3);

const formattedDate = new Date(item.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// 把 content（用空行分段落）拆成段落数组
const contentParagraphs = (item.content || '')
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter((p) => p.length > 0);
---

<Base title={item.title} description={item.summary}>
  <!-- 详情页专属结构化数据 -->
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: item.title,
    description: item.summary,
    datePublished: item.date,
    articleSection: item.category,
    image: item.imageUrl || undefined,
    author: { '@type': 'Organization', name: item.source },
    publisher: { '@type': 'Organization', name: 'AI Agents Hub' },
    mainEntityOfPage: `https://gonglue.xyz/news/${item.slug}`,
  })} />

  <div class="container">
    <div class="news-detail-hero" style="max-width: 760px; margin: 0 auto;">
      <a href={`${base}/news`} style="color: var(--text-muted); font-size: 14px;">
        ← Back to AI News
      </a>

      <!-- 主图（来自 source 的 og:image） -->
      {item.imageUrl && (
        <div class="news-detail-image" style="margin-top: 20px; border-radius: 16px; overflow: hidden; aspect-ratio: 3/2; background: var(--surface-2);">
          <img
            src={item.imageUrl}
            alt={item.title}
            loading="eager"
            referrerpolicy="no-referrer"
            style="width: 100%; height: 100%; object-fit: cover; display: block;"
          />
        </div>
      )}

      <div style="margin-top: 24px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
        <span class="news-badge">{item.category}</span>
        <span style="font-size: 18px;">{categoryIcon[item.category]}</span>
      </div>

      <h1 style="margin-top: 14px;">{item.title}</h1>
      <div class="news-detail-meta">
        <span class="source">{item.source}</span> · {formattedDate}
      </div>
    </div>

    <div class="prose" style="max-width: 760px; margin: 0 auto;">
      <!-- 摘要（Lead paragraph） -->
      <p style="font-size: 19px; color: var(--text); line-height: 1.7; font-weight: 500; margin-top: 8px;">
        {item.summary}
      </p>

      <!-- 完整正文（人工改写后的段落） -->
      {contentParagraphs.length > 0 && (
        <div class="news-content" style="margin-top: 28px;">
          {contentParagraphs.map((para) => (
            <p style="font-size: 17px; color: var(--text); line-height: 1.75; margin: 0 0 20px;">
              {para}
            </p>
          ))}
        </div>
      )}

      <div class="verdict-box" style="margin-top: 36px;">
        <div class="label">Read the full story</div>
        <p style="margin: 0 0 14px; color: var(--text);">
          This is a paraphrased summary of reporting from <strong>{item.source}</strong>. For the
          complete article, original reporting, and full context, visit the source.
        </p>
        <a href={item.sourceUrl} target="_blank" rel="noopener noreferrer" class="btn primary">
          Read full article on {item.source} →
        </a>
      </div>

      {item.tags.length > 0 && (
        <div style="margin-top: 32px; display: flex; gap: 8px; flex-wrap: wrap;">
          {item.tags.map((tag) => <span class="badge host">#{tag}</span>)}
        </div>
      )}
    </div>

    {related.length > 0 && (
      <section class="section">
        <div class="section-head">
          <h2>More in {item.category}</h2>
        </div>
        <div class="news-grid">
          {related.map((n) => (
            <a href={`${base}/news/${n.slug}`} class="news-card">
              {n.imageUrl ? (
                <div class="news-cover" style={`background-image: url(${n.imageUrl}); background-size: cover; background-position: center;`}>
                  <span class="cover-cat">{n.category}</span>
                </div>
              ) : (
                <div class="news-cover">
                  <div class="cover-bg" style={`background: ${categoryAccent[n.category]}`}></div>
                  <div class="cover-icon">{categoryIcon[n.category]}</div>
                  <span class="cover-cat">{n.category}</span>
                </div>
              )}
              <div class="news-body">
                <h3>{n.title}</h3>
                <p class="news-summary">{n.summary}</p>
                <div class="news-meta">
                  <span class="source">{n.source}</span>
                  <span>{n.date}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Base>