---
import Base from '../layouts/Base.astro';
import AgentCard from '../components/AgentCard.astro';
import { agents, categories, getFeatured, type Category } from '../data/agents';

const featured = getFeatured();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base>
  <section class="hero">
    <div class="container">
      <h1>Find the right <span class="grad">AI agent</span><br />for the job.</h1>
      <p>
        A hand-picked directory of AI agents for coding, research, browsing, and automation.
        No noise — just what's worth your time, with honest notes on each.
      </p>
      <div class="search-wrap">
        <input
          type="text"
          id="search"
          placeholder="Search agents, e.g. “coding”, “open source”, “browser”…"
          autocomplete="off"
        />
      </div>
    </div>
  </section>

  <!-- Editor's intro: signals editorial content, not auto-aggregator -->
  <section class="section section-editorial" aria-label="About this directory">
    <div class="container">
      <div class="editorial-intro">
        <p class="editorial-lead">
          <strong>AI Agents Hub is an independent editorial project.</strong>
          We hand-pick every agent on this site, write the description ourselves,
          and only list tools that have real users and a clear use case.
          The directory is updated weekly; a new long-form analysis post goes
          live every week or two.
        </p>
        <p class="editorial-detail">
          No paid placements, no auto-generated listings, no SEO scraping. If a
          tool is listed here, it cleared our four-point bar (real traction,
          clear use case, accessible, distinct). If we get something wrong, the
          tool wins — and we update the entry to reflect what users actually
          report. The blog is where we publish deeper comparisons and how-tos
          drawn from this directory.
        </p>
        <p class="editorial-meta">
          Last directory update: 2026-07-21 · 62 agents across 9 categories ·
          17 long-form analysis posts · Maintained by
          <a href="/about#editorial-team">the editorial team</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Featured -->
  <section class="section" id="featured">
    <div class="container">
      <div class="section-head">
        <h2>Featured</h2>
        <span class="count">{featured.length} picks</span>
      </div>
      <div class="grid" id="featured-grid">
        {featured.map((agent) => <AgentCard agent={agent} base={base} />)}
      </div>
    </div>
  </section>

  <!-- All agents, filterable -->
  <section class="section" id="categories">
    <div class="container">
      <div class="section-head">
        <h2>Browse all</h2>
        <span class="count" id="result-count">{agents.length} agents</span>
      </div>

      <div class="pills" id="filter-pills">
        <button class="pill active" data-cat="all">All</button>
        {categories.map((c) => (
          <button class="pill" data-cat={c.id}>{c.label}</button>
        ))}
      </div>

      <div class="grid" id="agent-grid">
        {agents.map((agent) => (
          <div class="card-wrap" data-name={agent.name.toLowerCase()} data-cat={agent.category} data-tags={agent.tags.join(' ')}>
            <AgentCard agent={agent} base={base} />
          </div>
        ))}
      </div>

      <p class="empty hidden" id="empty-state">No agents match your search.</p>
    </div>
  </section>
</Base>

<style>
  .section-editorial {
    padding: 40px 0 24px;
  }
  .editorial-intro {
    max-width: 760px;
    margin: 0 auto;
    text-align: left;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px 32px;
  }
  .editorial-lead {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 12px;
  }
  .editorial-detail {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0 0 12px;
  }
  .editorial-meta {
    font-size: 13px;
    color: var(--text-muted);
    margin: 0;
  }
  .editorial-meta a {
    color: #818cf8;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

<script is:inline>
  const pills = document.querySelectorAll('#filter-pills .pill');
  const cards = document.querySelectorAll('#agent-grid .card-wrap');
  const search = document.getElementById('search');
  const empty = document.getElementById('empty-state');
  const count = document.getElementById('result-count');
  const total = cards.length;

  let currentCat = 'all';
  let currentQuery = '';

  function apply() {
    let visible = 0;
    cards.forEach((card) => {
      const el = card;
      const matchCat = currentCat === 'all' || el.dataset.cat === currentCat;
      const matchQ =
        currentQuery === '' ||
        el.dataset.name.includes(currentQuery) ||
        (el.dataset.tags || '').includes(currentQuery);
      const show = matchCat && matchQ;
      el.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    if (count) count.textContent = `${visible} ${visible === 1 ? 'agent' : 'agents'}`;
    if (empty) empty.classList.toggle('hidden', visible !== 0);
  }

  pills.forEach((pill) => {
    pill.addEventListener('click', () => {
      pills.forEach((p) => p.classList.remove('active'));
      pill.classList.add('active');
      currentCat = pill.dataset.cat || 'all';
      apply();
    });
  });

  if (search) {
    search.addEventListener('input', (e) => {
      currentQuery = e.target.value.toLowerCase().trim();
      apply();
    });
  }
</script>
