---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---

<Base title="Not found">
  <section class="hero" style="padding-top: 120px; min-height: 50vh;">
    <div class="container">
      <h1>404 — <span class="grad">agent not found</span></h1>
      <p>This page doesn't exist. Maybe it shipped itself off to a new endpoint.</p>
      <div class="detail-actions" style="justify-content: center;">
        <a href={`${base}/`} class="btn primary">← Back home</a>
        <a href={`${base}/#categories`} class="btn">Browse agents</a>
      </div>
    </div>
  </section>
</Base>
