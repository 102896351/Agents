---
import type { Agent } from '../data/agents';
import { licenseLabel, difficultyLabel } from '../utils/labels';

interface Props {
  agent: Agent;
  base?: string; // URL 前缀，用于 GitHub Pages 子路径
}
const { agent, base = import.meta.env.BASE_URL.replace(/\/$/, '') } = Astro.props;
---

<a href={`${base}/agent/${agent.slug}`} class="card">
  <div class="card-top">
    <h3>{agent.name}</h3>
    {agent.stars && (
      <span class="stars-badge" title={`${agent.stars.toLocaleString()} GitHub stars`}>
        <svg class="stars-icon" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true"><path fill="currentColor" d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
        {(agent.stars / 1000).toFixed(1)}k
      </span>
    )}
  </div>
  <p class="tagline">{agent.tagline}</p>
  <div class="card-meta">
    <span class={`badge ${agent.license}`}>{licenseLabel(agent.license)}</span>
    {agent.selfHost && <span class="badge host">Self-host</span>}
    <span class="badge host">{difficultyLabel(agent.difficulty)}</span>
  </div>
</a>
