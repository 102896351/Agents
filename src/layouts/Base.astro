---
import '../styles/global.css';
import { agents } from '../data/agents';

const { title, description } = Astro.props as {
  title?: string;
  description?: string;
};

const siteName = 'AI Agents Hub';
const finalTitle = title ? `${title} · ${siteName}` : `${siteName} — A curated directory of AI agents`;
const finalDesc =
  description ||
  'Discover, compare, and choose AI agents for coding, research, browsing, automation, and more. Hand-picked and updated regularly.';
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://example.com').toString();
// 动态读取 base 路径，避免硬编码（适配自定义域名 vs github.io/仓库名）
const B = import.meta.env.BASE_URL; // 末尾带 /，如 '/' 或 '/Agents/'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${B}favicon.svg`} />
    <title>{finalTitle}</title>
    <meta name="description" content={finalDesc} />
    <link rel="canonical" href={canonical} />

    <!-- SEO: explicit indexing directives -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="author" content="AI Agents Hub" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#6366f1" />

    <!-- Open Graph -->
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDesc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="AI Agents Hub" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDesc} />

    <!-- Hint to browsers: this site works with or without JS -->
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- Google AdSense -->
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1606763409380030"
      crossorigin="anonymous"
    ></script>

    <!-- Google Analytics (GA4) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-GEVLL2XDFD"
    ></script>
    <script is:inline define:vars={{ GA_ID: 'G-GEVLL2XDFD' }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', GA_ID);
    </script>

    <!-- JSON-LD: 让搜索引擎把列表理解成目录结构 -->
    {agents.length > 0 && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          '@context': 'https://www.schema.org',
          '@type': 'ItemList',
          name: 'AI Agents Hub — A curated directory of AI agents',
          description: finalDesc,
          url: 'https://gonglue.xyz/',
          numberOfItems: agents.length,
          itemListElement: agents.map((a, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            name: a.name,
            url: `https://gonglue.xyz/agent/${a.slug}`,
            description: a.tagline,
          })),
        })}
      />
    )}

    <!-- JSON-LD: WebSite + SearchAction for sitelinks search box -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://www.schema.org',
        '@type': 'WebSite',
        name: 'AI Agents Hub',
        url: 'https://gonglue.xyz/',
        description: finalDesc,
        inLanguage: 'en',
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: 'https://gonglue.xyz/?q={search_term_string}',
          },
          'query-input': 'required name=search_term_string',
        },
      })}
    />

    <!-- 页面级 head 内容插槽（如详情页的 SoftwareApplication JSON-LD）-->
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={B} class="brand">
          <img src={`${B}favicon.svg`} alt="" />
          AI Agents Hub
        </a>
        <nav class="nav">
          <a href={`${B}#categories`}>Categories</a>
          <a href={`${B}#featured`}>Featured</a>
          <a href={`${B}news`}>News</a>
          <a href={`${B}about`}>About</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="footer-brand">
          <a href={B} class="footer-brand-link">AI Agents Hub</a>
          <span class="footer-brand-sep">·</span>
          <span class="footer-brand-year">© 2026</span>
        </p>
        <nav class="footer-nav" aria-label="Site legal and info">
          <a href={`${B}disclaimer`}>Disclaimer</a>
          <a href={`${B}privacy`}>Privacy</a>
          <a href={`${B}about`}>About</a>
          <a href={`${B}contact`}>Contact</a>
        </nav>
        <p class="footer-tagline">For technical exchange only · Use within the bounds of the law</p>
        <p class="footer-meta">
          Built with Astro · Hosted on GitHub Pages ·
          <a href="https://github.com" target="_blank" rel="noopener">View source</a>
        </p>
      </div>
    </footer>
  </body>
</html>
